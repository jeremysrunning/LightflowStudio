<Window x:Class="JeremyMediaToolkit.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Jeremy Media Toolkit v0.2" Height="780" Width="1040"
 MinHeight="680" MinWidth="900" WindowStartupLocation="CenterScreen">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="10,5"/></Style>
  <Style TargetType="TextBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="5"/></Style>
  <Style TargetType="ComboBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="5"/></Style>
 </Window.Resources>
 <Grid Margin="14">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <TextBlock Margin="4,0,4,12" FontSize="25" FontWeight="SemiBold" Text="Jeremy Media Toolkit"/>
  <TabControl Grid.Row="1" x:Name="MainTabs">
   <TabItem Header="Batch Encode"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="12">
    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Margin="4" VerticalAlignment="Center" Text="Video folder"/><TextBox x:Name="InputFolder" Grid.Row="0" Grid.Column="1"/>
    <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Click="BrowseInput_Click"/>
    <TextBlock Grid.Row="1" Margin="4" VerticalAlignment="Center" Text="LUT"/><ComboBox x:Name="LutSelection" Grid.Row="1" Grid.Column="1"
     DisplayMemberPath="DisplayName" SelectedValuePath="FilePath"/>
    <Button Grid.Row="1" Grid.Column="2" Content="Refresh" Click="RefreshLuts_Click"/>
    <TextBlock Grid.Row="2" Margin="4" VerticalAlignment="Center" Text="Resolution"/><ComboBox x:Name="Resolution" Grid.Row="2" Grid.Column="1" SelectedIndex="0">
     <ComboBoxItem Content="1080p"/><ComboBoxItem Content="4K UHD"/><ComboBoxItem Content="Source resolution"/></ComboBox>
    <TextBlock Grid.Row="3" Margin="4" VerticalAlignment="Center" Text="Recovery mode"/><ComboBox x:Name="RecoveryMode" Grid.Row="3" Grid.Column="1" SelectedIndex="0">
     <ComboBoxItem Content="Normal"/><ComboBoxItem Content="Salvage audio + video"/><ComboBoxItem Content="Video only"/></ComboBox>
    <CheckBox x:Name="Recursive" Grid.Row="4" Grid.Column="1" Margin="8,6" Content="Include subfolders"/>
    <CheckBox x:Name="SkipExisting" Grid.Row="5" Grid.Column="1" Margin="8,6" IsChecked="True" Content="Skip completed output files"/>
    <StackPanel Grid.Row="6" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4">
     <Button x:Name="StartButton" Content="Start Encoding" Click="Start_Click"/><Button x:Name="CancelButton" Content="Cancel" IsEnabled="False" Click="Cancel_Click"/>
    </StackPanel>
    <TextBlock Grid.Row="7" Grid.ColumnSpan="3" x:Name="CurrentFileText" Margin="4" Text="Ready" TextTrimming="CharacterEllipsis"/>
    <ProgressBar Grid.Row="8" Grid.ColumnSpan="3" x:Name="FileProgress" Height="18" Margin="4" Maximum="100"/>
    <ProgressBar Grid.Row="9" Grid.ColumnSpan="3" x:Name="BatchProgress" Height="18" Margin="4" Maximum="100"/>
    <TextBlock Grid.Row="10" Grid.ColumnSpan="3" x:Name="EtaText" Margin="4"/>
    <TextBox Grid.Row="11" Grid.ColumnSpan="3" x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
   </Grid></ScrollViewer></TabItem>
   <TabItem Header="Media Tools"><Grid Margin="12">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <TextBlock Margin="4" TextWrapping="Wrap" Text="Select a video file, then inspect its metadata, verify decoding, rewrap it without transcoding, or create a 1080p editing proxy."/>
    <DockPanel Grid.Row="1"><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseMedia_Click"/><TextBox x:Name="MediaPath"/></DockPanel>
    <WrapPanel Grid.Row="2"><Button Content="Inspect Metadata" Click="Inspect_Click"/><Button Content="Verify / CSV Report" Click="Verify_Click"/>
     <Button Content="Lossless Rewrap" Click="Rewrap_Click"/><Button Content="Create 1080p Proxy" Click="Proxy_Click"/><Button Content="Generate Contact Sheet" Click="ContactSheet_Click"/></WrapPanel>
    <TextBox Grid.Row="3" x:Name="ToolsOutput" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
   </Grid></TabItem>
   <TabItem Header="Settings"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="22" MaxWidth="850" HorizontalAlignment="Stretch">
    <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
     <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" FontSize="20" FontWeight="SemiBold" Text="Application Settings"/>
    <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,5,0,14" Foreground="DimGray" TextWrapping="Wrap"
     Text="Choose the folders, tools, and defaults that should be restored whenever the application starts."/>
    <Separator Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,10"/>
    <TextBlock Grid.Row="3" Grid.ColumnSpan="3" Margin="4,2,4,6" FontSize="16" FontWeight="SemiBold" Text="Folders"/>
    <TextBlock Grid.Row="4" Margin="4" VerticalAlignment="Center" Text="Default video folder"/><TextBox x:Name="SettingsDefaultVideoFolder" Grid.Row="4" Grid.Column="1"/>
    <Button Grid.Row="4" Grid.Column="2" Content="Browse…" Click="BrowseDefaultVideoFolder_Click"/>
    <TextBlock Grid.Row="5" Margin="4" VerticalAlignment="Center" Text="LUT library folder"/><TextBox x:Name="SettingsLutFolder" Grid.Row="5" Grid.Column="1"/>
    <Button Grid.Row="5" Grid.Column="2" Content="Browse…" Click="BrowseSettingsLutFolder_Click"/>
    <Separator Grid.Row="6" Grid.ColumnSpan="3" Margin="0,12,0,10"/>
    <TextBlock Grid.Row="7" Grid.ColumnSpan="3" Margin="4,2,4,6" FontSize="16" FontWeight="SemiBold" Text="Batch Encode Defaults"/>
    <TextBlock Grid.Row="8" Margin="4" VerticalAlignment="Center" Text="Resolution"/><ComboBox x:Name="SettingsResolution" Grid.Row="8" Grid.Column="1">
     <ComboBoxItem Content="1080p"/><ComboBoxItem Content="4K UHD"/><ComboBoxItem Content="Source resolution"/></ComboBox>
    <TextBlock Grid.Row="9" Margin="4" VerticalAlignment="Center" Text="Recovery mode"/><ComboBox x:Name="SettingsRecoveryMode" Grid.Row="9" Grid.Column="1">
     <ComboBoxItem Content="Normal"/><ComboBoxItem Content="Salvage audio + video"/><ComboBoxItem Content="Video only"/></ComboBox>
    <StackPanel Grid.Row="10" Grid.Column="1" Margin="4">
     <CheckBox x:Name="SettingsRecursive" Margin="4" Content="Include subfolders by default"/>
     <CheckBox x:Name="SettingsSkipExisting" Margin="4" Content="Skip completed output files by default"/>
    </StackPanel>
    <Separator Grid.Row="11" Grid.ColumnSpan="3" Margin="0,12,0,10"/>
    <TextBlock Grid.Row="12" Grid.ColumnSpan="3" Margin="4,2,4,6" FontSize="16" FontWeight="SemiBold" Text="External Tools"/>
    <TextBlock Grid.Row="13" Margin="4" VerticalAlignment="Center" Text="FFmpeg executable"/><TextBox x:Name="SettingsFfmpegPath" Grid.Row="13" Grid.Column="1"/>
    <Button Grid.Row="13" Grid.Column="2" Content="Browse…" Click="BrowseSettingsFfmpeg_Click"/>
    <TextBlock Grid.Row="14" Grid.Column="1" Margin="6,0,4,10" Foreground="DimGray" TextWrapping="Wrap"
     Text="Leave blank to use a bundled FFmpeg or the first copy available on PATH. FFprobe is detected beside FFmpeg or on PATH."/>
    <DockPanel Grid.Row="15" Grid.ColumnSpan="3" Margin="0,8,0,0">
     <TextBlock x:Name="SettingsMessage" VerticalAlignment="Center" Foreground="DimGray"/>
     <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
      <Button Content="Restore Defaults" Click="ResetSettings_Click"/><Button Content="Save Settings" Click="SaveSettings_Click"/>
     </StackPanel>
    </DockPanel>
   </Grid></ScrollViewer></TabItem>
   <TabItem Header="Premiere Helper"><StackPanel Margin="18">
    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Experimental Premiere timeline clip exporter"/>
    <TextBlock Margin="0,8" TextWrapping="Wrap" Text="The included ExtendScript helper exports each clip on video track V1 as an individual file using sequence In/Out points. Visible timeline effects and adjustment layers are included. Test on a duplicate project first."/>
    <Button HorizontalAlignment="Left" Content="Open Premiere Helper Folder" Click="OpenPremiere_Click"/>
   </StackPanel></TabItem>
  </TabControl>
  <StatusBar Grid.Row="2"><TextBlock x:Name="StatusText" Text="Checking FFmpeg…"/></StatusBar>
 </Grid>
</Window>
