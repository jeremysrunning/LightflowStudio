<Window x:Class="LightflowStudio.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Lightflow Studio" Icon="Assets/Branding/LightflowStudio.ico"
 Height="940" Width="1280" MinHeight="720" MinWidth="1120" WindowStartupLocation="CenterScreen"
 Closing="Window_Closing">
 <Grid Background="{StaticResource WindowBrush}">
  <Grid.ColumnDefinitions><ColumnDefinition Width="224"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>

  <Border Grid.RowSpan="2" Background="{StaticResource NavigationBrush}" BorderBrush="#252832" BorderThickness="0,0,1,0">
   <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel Margin="20,20,20,12">
     <Image Source="Assets/Branding/jr-glow-source.png" Width="112" Height="112" Stretch="Uniform" HorizontalAlignment="Left"/>
     <TextBlock Margin="2,10,0,0" Foreground="{StaticResource TextBrush}" FontSize="17" FontWeight="SemiBold" Text="Lightflow Studio"/>
     <TextBlock Margin="2,3,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="VIDEO PROCESSING &amp; WORKFLOW"/>
    </StackPanel>
    <Border Grid.Row="1" Height="1" Margin="18,0,18,10" Background="#282C35"/>
    <ListBox Grid.Row="2" x:Name="Navigation" Style="{StaticResource NavigationList}" ItemContainerStyle="{StaticResource NavigationItem}"
     SelectedIndex="{Binding ElementName=MainTabs, Path=SelectedIndex, Mode=TwoWay}">
     <ListBoxItem IsSelected="True"><Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" TextAlignment="Center" FontFamily="Segoe UI Symbol" FontSize="16" LineHeight="20" LineStackingStrategy="BlockLineHeight" Text="▶"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Batch Encode"/></Grid></ListBoxItem>
     <ListBoxItem><Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" TextAlignment="Center" FontFamily="Segoe UI Symbol" FontSize="16" LineHeight="20" LineStackingStrategy="BlockLineHeight" Text="◇"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Media Tools"/></Grid></ListBoxItem>
     <ListBoxItem><Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" TextAlignment="Center" FontFamily="Segoe UI Symbol" FontSize="16" LineHeight="20" LineStackingStrategy="BlockLineHeight" Text="✦"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Premiere Helper"/></Grid></ListBoxItem>
     <ListBoxItem><Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" TextAlignment="Center" FontFamily="Segoe UI Symbol" FontSize="16" LineHeight="20" LineStackingStrategy="BlockLineHeight" Text="⚙"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Settings"/></Grid></ListBoxItem>
     <ListBoxItem><Grid Height="22"><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" TextAlignment="Center" FontFamily="Segoe UI Symbol" FontSize="16" LineHeight="20" LineStackingStrategy="BlockLineHeight" Text="●"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Text="About"/></Grid></ListBoxItem>
    </ListBox>
    <StackPanel Grid.Row="3" Margin="20,12,20,20">
     <Border Height="2" Margin="0,0,0,10" Background="{StaticResource BrandGradient}" CornerRadius="1"/>
     <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="JEREMY RUNNING PHOTOGRAPHY" TextWrapping="Wrap"/>
    </StackPanel>
   </Grid>
  </Border>

  <TabControl Grid.Column="1" x:Name="MainTabs" Style="{StaticResource ContentOnlyTabs}" SelectedIndex="0">
   <TabItem>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
     <Grid Margin="28,24,28,28">
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
      <StackPanel Margin="2,0,0,20">
       <TextBlock Style="{StaticResource PageTitle}" Text="Batch Encode"/>
       <TextBlock Style="{StaticResource PageSubtitle}" Margin="0,5,0,0" Text="Apply a LUT and create consistent, edit-ready H.264 files from an entire folder."/>
      </StackPanel>

      <Border Grid.Row="1" x:Name="BatchConfiguration" Style="{StaticResource Card}">
       <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <TextBlock Grid.ColumnSpan="2" Style="{StaticResource SectionTitle}" Margin="4,0,4,12" Text="Batch Setup"/>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
         <TextBlock Style="{StaticResource FieldLabel}" Text="VIDEO FOLDER"/>
         <DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseInput_Click"/><TextBox x:Name="InputFolder" TextChanged="InputFolder_TextChanged"/></DockPanel>
         <CheckBox x:Name="Recursive" Margin="6,5,6,0" Content="Include subfolders" Checked="Recursive_Changed" Unchecked="Recursive_Changed"/>
        </StackPanel>
        <Expander Grid.Row="2" Grid.ColumnSpan="2" Margin="4,8,4,0" IsExpanded="False">
         <Expander.Header>
          <StackPanel Orientation="Horizontal">
           <TextBlock Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Text="Files in this batch"/>
           <TextBlock x:Name="BatchFileSummary" Margin="10,0,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Choose a folder to see its videos"/>
          </StackPanel>
         </Expander.Header>
         <Border Margin="0,8,0,2" Background="#111318" BorderBrush="#303540" BorderThickness="1" CornerRadius="7" Padding="10">
          <Grid>
           <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
           <DockPanel Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
             <Button Padding="10,5" Content="All" Click="SelectAllBatchFiles_Click"/>
             <Button Padding="10,5" Content="None" Click="SelectNoBatchFiles_Click"/>
             <Button Padding="10,5" Content="Refresh" Click="RefreshBatchFiles_Click"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Uncheck any videos you want to skip."/>
           </DockPanel>
           <Grid Grid.Row="1" Margin="6,0,14,5">
            <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="88"/><ColumnDefinition Width="76"/><ColumnDefinition Width="90"/><ColumnDefinition Width="84"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Style="{StaticResource FieldLabel}" Text="FILE"/>
            <TextBlock Grid.Column="2" Style="{StaticResource FieldLabel}" Text="RESOLUTION"/>
            <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="FRAME RATE"/>
            <TextBlock Grid.Column="4" Style="{StaticResource FieldLabel}" Text="DURATION"/>
            <TextBlock Grid.Column="5" Style="{StaticResource FieldLabel}" Text="SIZE"/>
            <TextBlock Grid.Column="6" Style="{StaticResource FieldLabel}" Text="STATUS"/>
           </Grid>
           <ListBox Grid.Row="2" x:Name="BatchFileList" MaxHeight="230" BorderThickness="0" Background="Transparent"
            HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
             <DataTemplate>
              <Grid Margin="2,5" ToolTip="{Binding DetailsTooltip}">
               <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="88"/><ColumnDefinition Width="76"/><ColumnDefinition Width="90"/><ColumnDefinition Width="84"/></Grid.ColumnDefinitions>
               <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay}" Click="BatchFileSelection_Click"/>
               <TextBlock Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
               <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding ResolutionText}"/>
               <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding FrameRateText}"/>
               <TextBlock Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding DurationText}"/>
               <TextBlock Grid.Column="5" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="{Binding SizeText}"/>
               <Border Grid.Column="6" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#3B3218" BorderBrush="#8A7122" BorderThickness="1" CornerRadius="8" Padding="7,2" ToolTip="{Binding WarningTooltip}">
                <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasWarning}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Border.Style>
                <TextBlock Foreground="#F2D46B" FontSize="10" FontWeight="SemiBold" Text="{Binding WarningLabel}"/>
               </Border>
              </Grid>
             </DataTemplate>
            </ListBox.ItemTemplate>
           </ListBox>
          </Grid>
         </Border>
        </Expander>
        <Border Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="0,10,0,0" BorderBrush="#2A2E37" BorderThickness="0,1,0,0">
        <Grid>
         <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
         <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
         <StackPanel Margin="0,0,8,0">
          <TextBlock Style="{StaticResource FieldLabel}" Text="OUTPUT LOCATION"/>
          <ComboBox x:Name="OutputMode" SelectionChanged="OutputMode_SelectionChanged"><ComboBoxItem Content="Same folder as source"/><ComboBoxItem Content="Subfolder"/><ComboBoxItem Content="Specific folder"/></ComboBox>
         </StackPanel>
         <StackPanel Grid.Column="1" x:Name="OutputSameFolderPanel" Margin="8,0,0,0">
          <TextBlock Style="{StaticResource FieldLabel}" Text="FILENAME SUFFIX"/>
          <TextBox x:Name="OutputFilenameSuffix" TextChanged="OutputFilenameSuffix_TextChanged" LostKeyboardFocus="OutputDestination_LostKeyboardFocus"/>
         </StackPanel>
         <StackPanel Grid.Column="1" x:Name="OutputSubfolderPanel" Margin="8,0,0,0">
          <TextBlock Style="{StaticResource FieldLabel}" Text="SUBFOLDER NAME"/>
          <TextBox x:Name="OutputSubfolderName" TextChanged="OutputSubfolderName_TextChanged" LostKeyboardFocus="OutputDestination_LostKeyboardFocus"/>
         </StackPanel>
         <StackPanel Grid.Column="1" x:Name="OutputSpecificPanel" Margin="8,0,0,0">
          <TextBlock Style="{StaticResource FieldLabel}" Text="SPECIFIC OUTPUT FOLDER"/>
          <DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseOutputFolder_Click"/><TextBox x:Name="OutputSpecificFolder" LostKeyboardFocus="OutputDestination_LostKeyboardFocus"/></DockPanel>
         </StackPanel>
         <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5,0,0">
          <CheckBox x:Name="PreserveFolderStructure" Margin="6,5,6,0" Content="Preserve source folder structure" Visibility="Collapsed" ToolTip="Keep each file in the same relative subfolder beneath the output location."/>
          <CheckBox x:Name="OverwriteExisting" Margin="6,5,6,0" Content="Overwrite existing files"/>
         </WrapPanel>
        </Grid>
        </Border>
        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,10,8,0">
         <TextBlock Style="{StaticResource FieldLabel}" Text="LUT"/>
         <DockPanel><Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshLuts_Click"/><ComboBox x:Name="LutSelection" DisplayMemberPath="DisplayName" SelectedValuePath="FilePath" SelectionChanged="LutSelection_SelectionChanged"/></DockPanel>
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,10,0,0">
         <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource FieldLabel}" Text="RESOLUTION"/><ComboBox x:Name="Resolution" SelectedIndex="2" SelectionChanged="Resolution_SelectionChanged"><ComboBoxItem Content="480p (854×480)"/><ComboBoxItem Content="720p (1280×720)"/><ComboBoxItem Content="1080p (1920×1080)"/><ComboBoxItem Content="1440p (2560×1440)"/><ComboBoxItem Content="4K UHD (3840×2160)"/><ComboBoxItem Content="Source resolution"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="1" Margin="6,0,0,0"><TextBlock Style="{StaticResource FieldLabel}" Text="RECOVERY MODE"/><ComboBox x:Name="RecoveryMode" SelectedIndex="0"><ComboBoxItem Content="Normal"/><ComboBoxItem Content="Salvage audio + video"/><ComboBoxItem Content="Video only"/></ComboBox></StackPanel>
         </Grid>
        </StackPanel>
       </Grid>
      </Border>

      <Grid Grid.Row="2" Margin="0,0,0,14">
       <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
       <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Border x:Name="BatchStateBorder" Background="#17241F" BorderBrush="#285845" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="2,0,8,0">
         <TextBlock x:Name="BatchStateText" Foreground="{StaticResource SuccessBrush}" FontSize="11" Text="READY"/>
        </Border>
        <TextBlock x:Name="CurrentFileText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Choose a video folder to begin" TextTrimming="CharacterEllipsis"/>
       </StackPanel>
       <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button x:Name="CancelButton" Style="{StaticResource DangerButton}" Content="Cancel" IsEnabled="False" Click="Cancel_Click"/>
        <Button x:Name="PauseButton" Content="Pause" IsEnabled="False" Click="Pause_Click"/>
        <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" Content="Start Encoding" IsEnabled="False" Click="Start_Click"/>
       </StackPanel>
      </Grid>

      <Grid Grid.Row="3">
       <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
       <Border Style="{StaticResource Card}">
        <Grid>
         <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
         <TextBlock Style="{StaticResource SectionTitle}" Margin="4,0,4,12" Text="Encoding Progress"/>
         <DockPanel Grid.Row="1" Margin="4,0,4,4" LastChildFill="False"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Current file"/><TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Foreground="{StaticResource OrangeBrush}" Text="ACTIVE"/></DockPanel>
         <ProgressBar Grid.Row="2" x:Name="FileProgress" Style="{StaticResource FileProgressStyle}" Maximum="100"/>
         <DockPanel Grid.Row="3" Margin="4,14,4,4" LastChildFill="False"><TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Overall batch"/><TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" x:Name="EtaText" Foreground="{StaticResource MutedTextBrush}"/></DockPanel>
         <ProgressBar Grid.Row="4" x:Name="BatchProgress" Maximum="100"/>
        </Grid>
       </Border>
       <Border Grid.Row="1" Style="{StaticResource Card}">
        <Expander x:Name="ActivityLogExpander" IsExpanded="False">
         <Expander.Header><TextBlock Style="{StaticResource SectionTitle}" Text="Activity Log"/></Expander.Header>
         <Grid Margin="0,10,0,0">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <CheckBox x:Name="ShowEncodingDetails" HorizontalAlignment="Right" Margin="4,0,4,8" Content="Show encoding details"
           Checked="ShowEncodingDetails_Changed" Unchecked="ShowEncodingDetails_Changed"
           ToolTip="Include technical encoding messages from FFmpeg and additional file details in the activity log."/>
          <TextBox Grid.Row="1" x:Name="LogBox" Height="150" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Mono, Consolas" FontSize="12" VerticalContentAlignment="Top" HorizontalContentAlignment="Left" VerticalScrollBarVisibility="Auto"/>
         </Grid>
        </Expander>
       </Border>
      </Grid>
     </Grid>
    </ScrollViewer>
   </TabItem>

   <TabItem>
    <Grid Margin="28,24,28,28">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
     <StackPanel Margin="2,0,0,20"><TextBlock Style="{StaticResource PageTitle}" Text="Media Tools"/><TextBlock Style="{StaticResource PageSubtitle}" Margin="0,5,0,0" Text="Inspect, verify, rewrap, proxy, or create a visual contact sheet from one media file."/></StackPanel>
     <Border Grid.Row="1" Style="{StaticResource Card}">
      <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="MEDIA FILE"/><DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseMedia_Click"/><TextBox x:Name="MediaPath"/></DockPanel></StackPanel>
     </Border>
     <Border Grid.Row="2" Style="{StaticResource Card}">
      <StackPanel><TextBlock Style="{StaticResource SectionTitle}" Margin="4,0,4,10" Text="Choose an action"/>
       <WrapPanel><Button Content="Inspect Metadata" Click="Inspect_Click"/><Button Content="Verify / CSV Report" Click="Verify_Click"/><Button Content="Lossless Rewrap" Click="Rewrap_Click"/><Button Content="Create 1080p Proxy" Click="Proxy_Click"/><Button Content="Generate Contact Sheet" Click="ContactSheet_Click"/></WrapPanel>
      </StackPanel>
     </Border>
     <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Style="{StaticResource SectionTitle}" Margin="4,0,4,10" Text="Tool Output"/><TextBox Grid.Row="1" x:Name="ToolsOutput" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Mono, Consolas" FontSize="12" VerticalContentAlignment="Top" HorizontalContentAlignment="Left" VerticalScrollBarVisibility="Auto"/></Grid></Border>
    </Grid>
   </TabItem>

   <TabItem>
    <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="28,24,28,28">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
     <StackPanel Margin="2,0,0,20"><TextBlock Style="{StaticResource PageTitle}" Text="Premiere Helper"/><TextBlock Style="{StaticResource PageSubtitle}" Margin="0,5,0,0" Text="Export individual timeline clips from Premiere Pro with the included ExtendScript workflow."/></StackPanel>
     <Border Grid.Row="1" Style="{StaticResource Card}">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
       <StackPanel Margin="4"><TextBlock Style="{StaticResource SectionTitle}" Text="Experimental timeline exporter"/><TextBlock Margin="0,10,20,16" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" LineHeight="20" Text="The included helper exports each clip on video track V1 as an individual file using sequence In/Out points. Visible timeline effects and adjustment layers are included. Test on a duplicate project first."/><Button HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}" Content="Open Premiere Helper Folder" Click="OpenPremiere_Click"/></StackPanel>
       <Image Grid.Column="1" Source="Assets/Branding/jr-glow-source.png" Stretch="Uniform" Opacity="0.78"/>
      </Grid>
     </Border>
     <Border Grid.Row="2" Background="#1D171B" BorderBrush="#55303C" BorderThickness="1" CornerRadius="9" Padding="14"><TextBlock Foreground="#E9BAC7" TextWrapping="Wrap" Text="Tip: duplicate the Premiere project before running timeline automation, and confirm the Adobe Media Encoder preset before a long export."/></Border>
    </Grid></ScrollViewer>
   </TabItem>

   <TabItem>
    <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="28,24,28,28">
     <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
     <StackPanel Margin="2,0,0,20"><TextBlock Style="{StaticResource PageTitle}" Text="Settings"/><TextBlock Style="{StaticResource PageSubtitle}" Margin="0,5,0,0" Text="Choose the folders, tools, and defaults restored whenever the application starts."/></StackPanel>
     <Border Grid.Row="1" Style="{StaticResource Card}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <TextBlock Grid.ColumnSpan="2" Style="{StaticResource SectionTitle}" Margin="4,0,4,12" Text="Folders"/>
      <StackPanel Grid.Row="1" Grid.ColumnSpan="2"><TextBlock Style="{StaticResource FieldLabel}" Text="DEFAULT VIDEO FOLDER"/><DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseDefaultVideoFolder_Click"/><TextBox x:Name="SettingsDefaultVideoFolder"/></DockPanel></StackPanel>
      <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0"><TextBlock Style="{StaticResource FieldLabel}" Text="LUT LIBRARY FOLDER"/><DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseSettingsLutFolder_Click"/><TextBox x:Name="SettingsLutFolder"/></DockPanel></StackPanel>
     </Grid></Border>
     <Border Grid.Row="2" Style="{StaticResource Card}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <TextBlock Grid.ColumnSpan="2" Style="{StaticResource SectionTitle}" Margin="4,0,4,12" Text="Batch Encode Defaults"/>
      <StackPanel Grid.Row="1" Margin="0,0,8,0"><TextBlock Style="{StaticResource FieldLabel}" Text="RESOLUTION"/><ComboBox x:Name="SettingsResolution"><ComboBoxItem Content="480p (854×480)"/><ComboBoxItem Content="720p (1280×720)"/><ComboBoxItem Content="1080p (1920×1080)"/><ComboBoxItem Content="1440p (2560×1440)"/><ComboBoxItem Content="4K UHD (3840×2160)"/><ComboBoxItem Content="Source resolution"/></ComboBox></StackPanel>
      <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0"><TextBlock Style="{StaticResource FieldLabel}" Text="RECOVERY MODE"/><ComboBox x:Name="SettingsRecoveryMode"><ComboBoxItem Content="Normal"/><ComboBoxItem Content="Salvage audio + video"/><ComboBoxItem Content="Video only"/></ComboBox></StackPanel>
      <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="4,8,0,0"><CheckBox x:Name="SettingsRecursive" Content="Include subfolders by default" Checked="SettingsRecursive_Changed" Unchecked="SettingsRecursive_Changed"/><CheckBox x:Name="SettingsPreserveFolderStructure" Content="Preserve source folder structure by default" Visibility="Collapsed"/><CheckBox x:Name="SettingsOverwriteExisting" Content="Overwrite existing output files by default"/></WrapPanel>

     </Grid></Border>
     <Border Grid.Row="3" Style="{StaticResource Card}">
      <StackPanel>
       <TextBlock Style="{StaticResource SectionTitle}" Margin="4,0,4,4" Text="Encoding Quality"/>
       <TextBlock Margin="4,0,4,12" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Choose a named starting point, then fine-tune individual options. NVIDIA NVENC is available now; CPU, AMD, and Intel backends are reserved for later releases."/>
       <DockPanel>
        <Button DockPanel.Dock="Right" Content="Apply Preset" Click="ApplyEncodingPreset_Click"/>
        <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="NAMED PRESET"/><ComboBox x:Name="SettingsEncodingPreset"><ComboBoxItem Content="Recommended"/><ComboBoxItem Content="Maximum Quality"/><ComboBoxItem Content="Fast Preview"/><ComboBoxItem Content="Efficient HEVC"/><ComboBoxItem Content="Custom" IsEnabled="False"/></ComboBox></StackPanel>
       </DockPanel>
       <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="ENCODER"/><ComboBox x:Name="SettingsEncoderBackend" IsEnabled="False"><ComboBoxItem Content="NVIDIA NVENC"/></ComboBox></StackPanel>
        <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FieldLabel}" Text="VIDEO CODEC"/><ComboBox x:Name="SettingsVideoCodec"><ComboBoxItem Content="H.264"/><ComboBoxItem Content="HEVC (H.265)"/></ComboBox></StackPanel>
        <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="CONTAINER"/><ComboBox x:Name="SettingsContainer"><ComboBoxItem Content="MP4"/><ComboBoxItem Content="MKV"/><ComboBoxItem Content="MOV"/></ComboBox></StackPanel>
        <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FieldLabel}" Text="AUDIO"/><ComboBox x:Name="SettingsAudioMode"><ComboBoxItem Content="Copy source"/><ComboBoxItem Content="AAC"/><ComboBoxItem Content="No audio"/></ComboBox></StackPanel>
       </Grid>
       <Expander Margin="4,12,4,0" Header="Advanced encoding options" Foreground="{StaticResource TextBrush}">
        <StackPanel Margin="0,8,0,0">
         <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="NVENC PRESET (P1–P7)"/><TextBox x:Name="SettingsEncoderPreset"/></StackPanel>
          <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FieldLabel}" Text="TUNING"/><ComboBox x:Name="SettingsTune"><ComboBoxItem Content="High quality"/><ComboBoxItem Content="Low latency"/><ComboBoxItem Content="Ultra-low latency"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="RATE CONTROL"/><ComboBox x:Name="SettingsRateControl"><ComboBoxItem Content="Constant quality"/><ComboBoxItem Content="Variable bitrate"/><ComboBoxItem Content="Constant bitrate"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FieldLabel}" Text="MULTIPASS"/><ComboBox x:Name="SettingsMultipass"><ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Quarter resolution"/><ComboBoxItem Content="Full resolution"/></ComboBox></StackPanel>
         </Grid>
         <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="QUALITY (0–51)"/><TextBox x:Name="SettingsQuality"/></StackPanel>
          <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FieldLabel}" Text="TARGET BITRATE (MBPS)"/><TextBox x:Name="SettingsTargetBitrate"/></StackPanel>
          <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="MAX BITRATE (MBPS)"/><TextBox x:Name="SettingsMaxBitrate"/></StackPanel>
          <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FieldLabel}" Text="AQ STRENGTH (1–15)"/><TextBox x:Name="SettingsAqStrength"/></StackPanel>
         </Grid>
         <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="PIXEL FORMAT"/><ComboBox x:Name="SettingsPixelFormat"><ComboBoxItem Content="8-bit YUV 4:2:0"/><ComboBoxItem Content="10-bit P010 (HEVC)"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FieldLabel}" Text="FRAME RATE"/><ComboBox x:Name="SettingsFrameRate"><ComboBoxItem Content="Source"/><ComboBoxItem Content="23.976"/><ComboBoxItem Content="24"/><ComboBoxItem Content="25"/><ComboBoxItem Content="29.97"/><ComboBoxItem Content="30"/><ComboBoxItem Content="50"/><ComboBoxItem Content="59.94"/><ComboBoxItem Content="60"/></ComboBox></StackPanel>
          <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FieldLabel}" Text="AAC BITRATE (KBPS)"/><TextBox x:Name="SettingsAudioBitrate"/></StackPanel>
          <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FieldLabel}" Text="AUDIO SAMPLE RATE"/><ComboBox x:Name="SettingsAudioSampleRate"><ComboBoxItem Content="Source"/><ComboBoxItem Content="44.1 kHz"/><ComboBoxItem Content="48 kHz"/><ComboBoxItem Content="96 kHz"/></ComboBox></StackPanel>
         </Grid>
         <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
          <StackPanel><TextBlock Style="{StaticResource FieldLabel}" Text="AUDIO CHANNELS"/><ComboBox x:Name="SettingsAudioChannels"><ComboBoxItem Content="Source"/><ComboBoxItem Content="Mono"/><ComboBoxItem Content="Stereo"/></ComboBox></StackPanel>
          <WrapPanel Grid.Column="1" Margin="8,22,0,0"><CheckBox x:Name="SettingsDeinterlace" Content="Deinterlace"/><CheckBox x:Name="SettingsSpatialAq" Content="Spatial AQ"/><CheckBox x:Name="SettingsTemporalAq" Content="Temporal AQ"/><CheckBox x:Name="SettingsFastStart" Content="Fast start for MP4/MOV"/></WrapPanel>
         </Grid>
        </StackPanel>
       </Expander>
      </StackPanel>
     </Border>
     <Border Grid.Row="4" Style="{StaticResource Card}">
      <StackPanel>
       <DockPanel Margin="4,0,4,12">
        <Button DockPanel.Dock="Right" Padding="12,6" Content="Check Again" Click="CheckDependencies_Click"/>
        <StackPanel><TextBlock Style="{StaticResource SectionTitle}" Text="Encoding Requirements"/><TextBlock x:Name="DependencySummary" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Checking the tools needed for encoding…"/></StackPanel>
       </DockPanel>
       <ItemsControl x:Name="DependencyResults" Margin="4,0,4,12">
        <ItemsControl.ItemTemplate><DataTemplate>
         <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <Ellipse Width="9" Height="9" HorizontalAlignment="Left" VerticalAlignment="Center"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{StaticResource WarningBrush}"/><Style.Triggers><DataTrigger Binding="{Binding IsReady}" Value="True"><Setter Property="Fill" Value="{StaticResource SuccessBrush}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
          <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Text="{Binding Name}"/>
          <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="{Binding Summary}" ToolTip="{Binding Detail}"/>
          <ToggleButton Grid.Column="3" x:Name="RequirementHelpButton" Style="{StaticResource RequirementInfoButton}" Content="i"
           MouseEnter="RequirementHelp_MouseEnter" MouseLeave="RequirementHelp_MouseLeave"/>
          <Popup IsOpen="{Binding IsChecked, ElementName=RequirementHelpButton, Mode=TwoWay}" PlacementTarget="{Binding ElementName=RequirementHelpButton}" Placement="Right" HorizontalOffset="8" AllowsTransparency="True" StaysOpen="True">
           <Border Width="340" Padding="14" Background="#20242C" BorderBrush="#596270" BorderThickness="1" CornerRadius="8"
            Tag="{Binding ElementName=RequirementHelpButton}" MouseLeftButtonUp="RequirementHelpPopup_Click">
            <StackPanel><TextBlock Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Text="{Binding Name}"/><TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="{Binding Resolution}"/><TextBlock Margin="0,7,0,0" Foreground="#7F8998" FontSize="11" TextWrapping="Wrap" Text="{Binding Detail}"/></StackPanel>
           </Border>
          </Popup>
         </Grid>
        </DataTemplate></ItemsControl.ItemTemplate>
       </ItemsControl>
       <TextBlock Style="{StaticResource FieldLabel}" Text="FFMPEG EXECUTABLE"/>
       <DockPanel><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseSettingsFfmpeg_Click"/><TextBox x:Name="SettingsFfmpegPath"/></DockPanel>
       <TextBlock Margin="6,5,4,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Leave blank to use a bundled FFmpeg or the first copy available on PATH. FFprobe is detected beside FFmpeg or on PATH."/>
      </StackPanel>
     </Border>
     <DockPanel Grid.Row="5" Margin="2,0"><TextBlock x:Name="SettingsMessage" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Restore Defaults" Click="ResetSettings_Click"/><Button Style="{StaticResource PrimaryButton}" Content="Save Settings" Click="SaveSettings_Click"/></StackPanel></DockPanel>
    </Grid></ScrollViewer>
   </TabItem>

   <TabItem>
    <Grid Margin="28,24,28,28"><Border Style="{StaticResource Card}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="620" Padding="28">
     <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="210"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Image Source="Assets/Branding/jr-glow-source.png" Width="190" Height="190" Stretch="Uniform"/>
      <StackPanel Grid.Column="1" Margin="24,10,0,0"><TextBlock Style="{StaticResource PageTitle}" Text="Lightflow Studio"/><TextBlock Margin="0,4,0,16" Foreground="{StaticResource OrangeBrush}" FontSize="12" FontWeight="SemiBold" Text="JEREMY RUNNING PHOTOGRAPHY"/><TextBlock Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" LineHeight="20" Text="Video processing and workflow tools for batch encoding, media inspection, recovery, and Premiere Pro exports."/><Border Height="2" Margin="0,22,0,16" Background="{StaticResource BrandGradient}"/><TextBlock x:Name="AboutVersionText" Foreground="{StaticResource MutedTextBrush}"/></StackPanel>
     </Grid>
    </Border></Grid>
   </TabItem>
  </TabControl>

  <Border Grid.Row="1" Grid.Column="1" Background="#111319" BorderBrush="#252832" BorderThickness="0,1,0,0" Padding="14,0">
   <DockPanel><Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/><TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="Checking FFmpeg…"/></DockPanel>
  </Border>
 </Grid>
</Window>
